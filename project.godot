; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Juice!"
run/main_scene="uid://cbx6w3pdk33od"
config/features=PackedStringArray("4.5")
config/icon="res://defaults/icon.png"

[autoload]

Game="*res://game/game.tscn"

[debug]

gdscript/warnings/unused_parameter=0
gdscript/warnings/unused_signal=0

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/mode=3
window/stretch/mode="viewport"

[editor_plugins]

enabled=PackedStringArray("res://addons/first_party/components/look_at/plugin.cfg", "res://addons/first_party/components/mouse_listener/plugin.cfg", "res://addons/first_party/subclasses/clickable_area_2d/plugin.cfg")

[gui]

